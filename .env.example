# ================================================================
# AI Newbie Web - Environment Configuration
# ================================================================

# Development Server
VITE_PORT=5174
VITE_HOST=localhost

# API Configuration (if needed)
VITE_API_URL=http://localhost:3000
VITE_API_TIMEOUT=30000

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEBUG=false

# Analytics (Optional)
VITE_GA_TRACKING_ID=
VITE_SENTRY_DSN=

# Social Media Links
VITE_FACEBOOK_URL=
VITE_TWITTER_URL=
VITE_LINKEDIN_URL=
VITE_GITHUB_URL=

# Contact Information
VITE_CONTACT_EMAIL=info@ainewbie.com
VITE_SUPPORT_EMAIL=support@ainewbie.com

# Build Configuration
VITE_BUILD_MODE=production
NODE_ENV=development
