# ================================================================
# AI Newbie Web - Environment Configuration
# Copy this to .env.local and fill in values
# ================================================================

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# App
VITE_APP_NAME=AINewbieVN
VITE_APP_URL=http://localhost:5174

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true

# Analytics (Optional)
# Google Analytics 4 — Get from: https://analytics.google.com → Admin → Data Streams
VITE_GA_ID=G-XXXXXXXXXX
VITE_SENTRY_DSN=

# Social Media Links
VITE_FACEBOOK_URL=
VITE_TWITTER_URL=
VITE_LINKEDIN_URL=
VITE_GITHUB_URL=

# Contact
VITE_CONTACT_EMAIL=info@ainewbievn.shop
VITE_SUPPORT_EMAIL=support@ainewbievn.shop
